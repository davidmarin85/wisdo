---
import type { Tool } from '@data/tools';
import { pricingConfig } from '@data/tools';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const pricing = pricingConfig[tool.pricing];
const stars = Math.round(tool.rating);
---

<article
  class="tool-card"
  data-category={tool.categorySlug}
  data-pricing={tool.pricing}
  data-rating={tool.rating}
  data-review-count={tool.reviewCount}
>
  <a href={`/tools/${tool.slug}/`} class="tool-card__link" aria-label={`Ver ${tool.name}`}>
    <div class="tool-card__header">
      <span class="tool-card__logo" role="img" aria-label={tool.name}>{tool.logo}</span>
      <div class="tool-card__title-group">
        <h3 class="tool-card__name">{tool.name}</h3>
        <span class="tool-card__category">{tool.category}</span>
      </div>
      <span class:list={['tag', pricing.colorClass]}>{pricing.label}</span>
    </div>

    <p class="tool-card__desc">{tool.description}</p>

    <div class="tool-card__tags">
      {tool.tags.slice(0, 3).map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>

    <div class="tool-card__footer">
      <div class="tool-card__rating" aria-label={`${tool.rating} de 5 estrellas`}>
        <span class="tool-card__stars">
          {Array.from({ length: 5 }, (_, i) => (
            <span class:list={['star', { 'star--filled': i < stars }]}>★</span>
          ))}
        </span>
        <span class="tool-card__rating-num">{tool.rating}</span>
        <span class="tool-card__review-count">({tool.reviewCount.toLocaleString('es')})</span>
      </div>
      <span class="tool-card__price">{tool.priceLabel}</span>
    </div>
  </a>
</article>

<style>
  .tool-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: box-shadow var(--transition-normal), transform var(--transition-normal), border-color var(--transition-normal);
    overflow: hidden;
  }

  .tool-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
    border-color: var(--color-gray-200);
  }

  .tool-card__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .tool-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .tool-card__logo {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
    width: 2.5rem;
    text-align: center;
  }

  .tool-card__title-group {
    flex: 1;
    min-width: 0;
  }

  .tool-card__name {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tool-card__category {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .tool-card__desc {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    line-height: var(--leading-relaxed);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tool-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tool-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .tool-card__rating {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
  }

  .tool-card__stars {
    display: flex;
  }

  .star {
    color: var(--color-gray-200);
    font-size: 0.85em;
    line-height: 1;
  }

  .star--filled {
    color: #F4A840;
  }

  .tool-card__rating-num {
    font-weight: var(--font-semibold);
    color: var(--color-dark);
  }

  .tool-card__review-count {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }

  .tool-card__price {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: right;
    flex-shrink: 0;
  }
</style>
