---
import SEO from '@components/SEO.astro';
import Nav from '@components/Nav.astro';
import '@styles/global.css';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  canonical?: string | undefined;
  ogImage?: string;
  navVariant?: 'dark' | 'light';
}

const {
  title,
  description,
  noindex = false,
  canonical,
  ogImage,
  navVariant = 'dark',
} = Astro.props;

const user = Astro.locals.user
  ? { email: Astro.locals.user.email ?? '' }
  : null;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <SEO
      title={title}
      description={description}
      noindex={noindex}
      canonical={canonical}
      ogImage={ogImage}
    />
  </head>
  <body>
    <Nav user={user} variant={navVariant} />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <div class="site-footer__inner">
          <a href="/" class="site-footer__logo" aria-label="wisdo inicio">
            <span class="site-footer__logo-dot" aria-hidden="true"></span>
            wisdo
            <span class="site-footer__logo-badge">MARKET</span>
          </a>
          <p class="site-footer__copy">
            &copy; 2026 wisdo Market &middot; Curated marketing &amp; sales tools
          </p>
          <nav class="site-footer__links" aria-label="Footer">
            <a href="/tools/">Market</a>
            <a href="/blog/">Blog</a>
          </nav>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-footer {
    background-color: var(--color-dark);
    color: rgb(255 255 255 / 0.5);
    padding: var(--space-10) 0;
    margin-top: auto;
  }

  .site-footer__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .site-footer__logo {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: white;
    letter-spacing: -0.02em;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .site-footer__logo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-green);
    box-shadow: 0 0 10px var(--color-green);
    flex-shrink: 0;
  }

  .site-footer__logo-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    color: #9D8CFF;
    border: 1px solid #3A3660;
    border-radius: 4px;
    padding: 2px 5px;
  }

  .site-footer__copy {
    font-size: var(--text-sm);
    margin-right: auto;
  }

  .site-footer__links {
    display: flex;
    gap: var(--space-6);
  }

  .site-footer__links a {
    font-size: var(--text-sm);
    color: inherit;
    transition: color var(--transition-fast);
  }

  .site-footer__links a:hover {
    color: white;
  }

  @media (max-width: 640px) {
    .site-footer__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-footer__copy {
      margin-right: 0;
    }
  }
</style>
