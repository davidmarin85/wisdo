---
import BaseLayout from '@layouts/BaseLayout.astro';
import ToolCard from '@components/ToolCard.astro';
import { tools, categories } from '@data/tools';

const featuredTools = tools.filter(t => t.featured);

const bestForMap: Record<string, string> = {
  apollo:    'Outreach a escala',
  kaspr:     'LinkedIn lead gen',
  krispcall: 'Ventas telefónicas',
  lemlist:   'Cold email multichannel',
  lusha:     'Enriquecimiento B2B',
  manychat:  'Chatbots & DMs',
};
---

<BaseLayout
  title="wisdo Market — El marketplace de herramientas para ventas"
  description="Encuentra, compara y elige las mejores herramientas de prospecting, outreach y automatización para tu equipo comercial."
  navVariant="dark"
>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero__content">
      <p class="hero__eyebrow">The marketing &amp; sales tool marketplace</p>
      <h1 class="hero__title">
        Every tool to find,<br />
        <span class="hero__title-accent">reach &amp; close</span> more customers.
      </h1>
      <p class="hero__subtitle">
        Herramientas evaluadas y comparadas para equipos comerciales<br class="hide-mobile" />
        en Latinoamérica. Sin afiliados, sin sesgos.
      </p>
      <form class="hero__search" action="/tools/" method="get" role="search">
        <svg class="hero__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="search" name="q" placeholder="Busca herramientas, casos de uso…" class="hero__search-input" aria-label="Buscar herramientas" autocomplete="off" />
        <button type="submit" class="hero__search-btn">Buscar</button>
      </form>
      <div class="hero__popular">
        <span class="hero__popular-label">Popular:</span>
        <a href="/tools/?q=cold+email" class="hero__popular-tag">Cold email</a>
        <a href="/tools/?q=linkedin" class="hero__popular-tag">LinkedIn data</a>
        <a href="/tools/?q=chatbot" class="hero__popular-tag">Chatbots</a>
        <a href="/tools/?q=lead+gen" class="hero__popular-tag">Lead gen</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-value">25+</span>
          <span class="hero__stat-label">Herramientas evaluadas</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-value">5</span>
          <span class="hero__stat-label">Categorías</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-value">100%</span>
          <span class="hero__stat-label">Hand-picked</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED TOOLS ===== -->
  <section class="marketplace" id="marketplace">
    <div class="container">
      <div class="marketplace__header">
        <div>
          <h2 class="marketplace__title">Herramientas destacadas</h2>
          <p class="marketplace__subtitle">Las favoritas de los equipos de ventas en Latinoamérica</p>
        </div>
        <a href="/tools/" class="btn btn--outline-dark">Ver todas →</a>
      </div>
      <div class="filter-pills" role="group" aria-label="Filtrar por categoría">
        {categories.map(cat => (
          <button
            class:list={['filter-pill', { 'filter-pill--active': cat.slug === 'all' }]}
            data-filter={cat.slug}
            type="button"
          >
            {cat.label}
          </button>
        ))}
      </div>
      <div class="tool-grid" id="tool-grid">
        {featuredTools.map(tool => (
          <ToolCard tool={tool} />
        ))}
      </div>
      <div class="marketplace__cta">
        <p>¿No encuentras lo que buscas?</p>
        <a href="/tools/" class="btn btn--purple">Ver el directorio completo</a>
      </div>
    </div>
  </section>

  <!-- ===== QUIZ / STACK DIAGNOSTIC ===== -->
  <section class="quiz" id="quiz">
    <div class="container">
      <p class="quiz__eyebrow">Stack Diagnostic</p>
      <h2 class="quiz__title">Find your perfect sales stack</h2>
      <p class="quiz__subtitle">4 preguntas para recomendarte las herramientas que se adaptan a tu situación.</p>

      <div class="quiz__frame">
        <div class="quiz__stepbar" id="quiz-stepbar" aria-label="Progreso del quiz">
          <div class="quiz__pill quiz__pill--active" data-s="1"></div>
          <div class="quiz__pill" data-s="2"></div>
          <div class="quiz__pill" data-s="3"></div>
          <div class="quiz__pill" data-s="4"></div>
        </div>

        <!-- Q1 -->
        <div class="quiz__q" id="quiz-q1">
          <p class="quiz__qlabel">Pregunta 1 de 4</p>
          <h3 class="quiz__qtitle">¿Qué tipo de negocio tienes?</h3>
          <div class="quiz__opts">
            <button class="quiz__opt" data-key="biz" data-val="agency" type="button">
              <span class="quiz__opt-name">Agencia</span>
              <span class="quiz__opt-desc">Gestionas clientes y campañas</span>
            </button>
            <button class="quiz__opt" data-key="biz" data-val="saas" type="button">
              <span class="quiz__opt-name">SaaS</span>
              <span class="quiz__opt-desc">Vendes software por suscripción</span>
            </button>
            <button class="quiz__opt" data-key="biz" data-val="consultant" type="button">
              <span class="quiz__opt-name">Consultor</span>
              <span class="quiz__opt-desc">Vendes tu expertise directamente</span>
            </button>
            <button class="quiz__opt" data-key="biz" data-val="ecommerce" type="button">
              <span class="quiz__opt-name">Ecommerce</span>
              <span class="quiz__opt-desc">Vendes productos online</span>
            </button>
          </div>
        </div>

        <!-- Q2 -->
        <div class="quiz__q" id="quiz-q2" hidden>
          <p class="quiz__qlabel">Pregunta 2 de 4</p>
          <h3 class="quiz__qtitle">¿En qué etapa está tu negocio?</h3>
          <div class="quiz__opts quiz__opts--3">
            <button class="quiz__opt" data-key="stage" data-val="validating" type="button">
              <span class="quiz__opt-name">Validando</span>
              <span class="quiz__opt-desc">Buscando product-market fit</span>
            </button>
            <button class="quiz__opt" data-key="stage" data-val="growing" type="button">
              <span class="quiz__opt-name">Creciendo</span>
              <span class="quiz__opt-desc">Tienes clientes, quieres más</span>
            </button>
            <button class="quiz__opt" data-key="stage" data-val="scaling" type="button">
              <span class="quiz__opt-name">Escalando</span>
              <span class="quiz__opt-desc">Operando y optimizando a escala</span>
            </button>
          </div>
        </div>

        <!-- Q3 -->
        <div class="quiz__q" id="quiz-q3" hidden>
          <p class="quiz__qlabel">Pregunta 3 de 4</p>
          <h3 class="quiz__qtitle">¿Cuál es tu mayor problema ahora mismo?</h3>
          <div class="quiz__opts">
            <button class="quiz__opt" data-key="problem" data-val="generate-leads" type="button">
              <span class="quiz__opt-name">Generar leads</span>
              <span class="quiz__opt-desc">No llegan suficientes prospectos</span>
            </button>
            <button class="quiz__opt" data-key="problem" data-val="close-sales" type="button">
              <span class="quiz__opt-name">Cerrar ventas</span>
              <span class="quiz__opt-desc">Los leads no están convirtiendo</span>
            </button>
            <button class="quiz__opt" data-key="problem" data-val="retain-customers" type="button">
              <span class="quiz__opt-name">Retener clientes</span>
              <span class="quiz__opt-desc">Se van antes de lo esperado</span>
            </button>
            <button class="quiz__opt" data-key="problem" data-val="automate-ops" type="button">
              <span class="quiz__opt-name">Automatizar ops</span>
              <span class="quiz__opt-desc">Los procesos manuales te frenan</span>
            </button>
          </div>
        </div>

        <!-- Q4 -->
        <div class="quiz__q" id="quiz-q4" hidden>
          <p class="quiz__qlabel">Pregunta 4 de 4</p>
          <h3 class="quiz__qtitle">¿Cuánto puedes invertir en herramientas al mes?</h3>
          <div class="quiz__opts quiz__opts--3">
            <button class="quiz__opt" data-key="budget" data-val="low" type="button">
              <span class="quiz__opt-name">Hasta €100</span>
              <span class="quiz__opt-desc">Bootstrapped, máximo impacto</span>
            </button>
            <button class="quiz__opt" data-key="budget" data-val="medium" type="button">
              <span class="quiz__opt-name">€100 – 500</span>
              <span class="quiz__opt-desc">Stack sólido y completo</span>
            </button>
            <button class="quiz__opt" data-key="budget" data-val="high" type="button">
              <span class="quiz__opt-name">€500 o más</span>
              <span class="quiz__opt-desc">Sin límites, solo lo mejor</span>
            </button>
          </div>
        </div>

        <!-- Result (injected by JS) -->
        <div class="quiz__result" id="quiz-result" hidden></div>

        <!-- Navigation -->
        <div class="quiz__nav" id="quiz-nav">
          <button class="quiz__back-btn" id="quiz-back" type="button" hidden>← Atrás</button>
          <button class="quiz__restart-btn" id="quiz-restart" type="button" hidden>Empezar de nuevo</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMPARATOR ===== -->
  <section class="comparator" id="comparator">
    <div class="container">
      <p class="comparator__eyebrow">Comparador interactivo</p>
      <h2 class="comparator__title">Compara herramientas</h2>
      <p class="comparator__subtitle">Selecciona hasta 3 herramientas y compáralas lado a lado.</p>

      <div class="comp-chips" id="comp-chips" role="group" aria-label="Seleccionar herramientas">
        {tools.map(tool => (
          <button class="comp-chip" data-slug={tool.slug} data-color={tool.color} data-mono={tool.mono} type="button" aria-pressed="false">
            <span class="comp-chip__mono" style={`background:${tool.color}`}>{tool.mono}</span>
            {tool.name}
          </button>
        ))}
      </div>

      <div id="comp-output">
        <p class="comp-empty">Selecciona al menos una herramienta para comparar.</p>
      </div>
    </div>
  </section>

  <!-- ===== FULL COMPARISON TABLE ===== -->
  <section class="compare-all" id="compare-all">
    <div class="container">
      <p class="compare-all__eyebrow">Tabla completa</p>
      <h2 class="compare-all__title">Todas las herramientas, de un vistazo</h2>
      <p class="compare-all__subtitle">Una comparativa honesta sin afiliados ni rankings pagados.</p>

      <div class="compare-all__scroll">
        <table class="all-table">
          <thead>
            <tr>
              <th class="all-table__th all-table__th--label">Herramienta</th>
              <th class="all-table__th">Categoría</th>
              <th class="all-table__th">Ideal para</th>
              <th class="all-table__th">Precio</th>
              <th class="all-table__th">Rating</th>
              <th class="all-table__th"></th>
            </tr>
          </thead>
          <tbody>
            {tools.map(tool => (
              <tr class="all-table__row">
                <td class="all-table__td all-table__tool-cell">
                  <span class="all-table__mono" style={`background:${tool.color}`}>{tool.mono}</span>
                  <span class="all-table__name">{tool.name}</span>
                </td>
                <td class="all-table__td">
                  <span class="all-table__cat">{tool.category}</span>
                </td>
                <td class="all-table__td all-table__bestfor">{bestForMap[tool.slug]}</td>
                <td class="all-table__td all-table__price">{tool.priceLabel}</td>
                <td class="all-table__td">
                  <span class="all-table__rating">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="#F5B33B" aria-hidden="true">
                      <path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7z"/>
                    </svg>
                    {tool.rating}
                  </span>
                </td>
                <td class="all-table__td">
                  <a href={tool.externalUrl} target="_blank" rel="noopener noreferrer" class="all-table__cta">
                    {tool.cta} →
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <div class="container cta-section__inner">
      <h2 class="cta-section__title">Build your sales stack<br />in one place</h2>
      <p class="cta-section__body">Browse vetted tools, compare them honestly, and start with the ones that fit your goals.</p>
      <div class="cta-section__btns">
        <a href="/tools/" class="cta-section__btn cta-section__btn--white">Explorar el marketplace</a>
        <a href="mailto:hola@wisdo.io" class="cta-section__btn cta-section__btn--outline">Sugerir una herramienta</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    background:
      radial-gradient(900px 460px at 72% -8%, rgba(108, 92, 231, 0.42), transparent 58%),
      radial-gradient(700px 400px at 8% 20%, rgba(19, 194, 138, 0.12), transparent 60%),
      #14121F;
    color: white;
    padding: var(--space-32) 0 var(--space-24);
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
  }

  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #9D8CFF;
    margin-bottom: var(--space-1);
  }

  .hero__title {
    font-size: clamp(var(--text-4xl), 6vw, 60px);
    font-weight: var(--font-bold);
    letter-spacing: -0.03em;
    line-height: var(--leading-tight);
    color: white;
    max-width: 16ch;
  }

  .hero__title-accent {
    background: linear-gradient(135deg, #A89AFF 0%, var(--color-green) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: var(--text-base);
    color: rgb(255 255 255 / 0.6);
    line-height: var(--leading-relaxed);
    max-width: 50ch;
  }

  .hero__search {
    display: flex;
    align-items: center;
    max-width: 520px;
    width: 100%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 14px;
    padding: 6px 8px 6px 18px;
    gap: 10px;
    margin-top: var(--space-2);
  }

  .hero__search-icon { color: rgb(255 255 255 / 0.4); flex-shrink: 0; }

  .hero__search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: 15px;
    color: white;
    color-scheme: dark;
    min-width: 0;
  }

  .hero__search-input::placeholder { color: rgb(255 255 255 / 0.35); }

  .hero__search-btn {
    padding: 10px 20px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    background: var(--color-green);
    color: #0B1F17;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .hero__search-btn:hover { opacity: 0.88; }

  .hero__popular {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__popular-label {
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgb(255 255 255 / 0.4);
  }

  .hero__popular-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgb(255 255 255 / 0.65);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 4px 12px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .hero__popular-tag:hover { background: rgba(255, 255, 255, 0.12); color: white; }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-10);
    margin-top: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid rgb(255 255 255 / 0.08);
    width: 100%;
    justify-content: center;
  }

  .hero__stat { display: flex; flex-direction: column; align-items: center; gap: var(--space-1); }

  .hero__stat-value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: white;
    letter-spacing: -0.02em;
  }

  .hero__stat-label {
    font-size: var(--text-xs);
    color: rgb(255 255 255 / 0.45);
    font-family: var(--font-mono);
    letter-spacing: 0.3px;
  }

  .hero__stat-divider { width: 1px; height: 40px; background-color: rgb(255 255 255 / 0.1); }

  /* ===== MARKETPLACE ===== */
  .marketplace {
    background-color: var(--color-white);
    padding: var(--space-20) 0 var(--space-24);
  }

  .marketplace__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .marketplace__title { font-size: var(--text-3xl); color: var(--color-dark); margin-bottom: var(--space-2); }
  .marketplace__subtitle { color: var(--color-text-muted); font-size: var(--text-base); }

  .filter-pills { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-8); }

  .filter-pill {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-gray-200);
    background-color: var(--color-white);
    color: var(--color-gray-600);
    cursor: pointer;
    transition: background-color var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
  }

  .filter-pill:hover { border-color: var(--color-purple); color: var(--color-purple); }
  .filter-pill--active { background-color: var(--color-purple); border-color: var(--color-purple); color: white; }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
    margin-bottom: var(--space-12);
  }

  .marketplace__cta {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    justify-content: center;
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-border);
  }

  .marketplace__cta p { color: var(--color-text-muted); font-size: var(--text-base); }

  /* ===== QUIZ ===== */
  .quiz {
    background-color: #0B0A14;
    padding: var(--space-24) 0;
    color: white;
  }

  .quiz__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #13C28A;
    margin-bottom: var(--space-4);
    text-align: center;
  }

  .quiz__title {
    font-size: clamp(var(--text-3xl), 4vw, 42px);
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: var(--space-3);
  }

  .quiz__subtitle {
    font-size: var(--text-base);
    color: rgb(255 255 255 / 0.55);
    text-align: center;
    margin-bottom: var(--space-12);
    max-width: 48ch;
    margin-left: auto;
    margin-right: auto;
  }

  .quiz__frame {
    max-width: 700px;
    margin: 0 auto;
  }

  .quiz__stepbar {
    display: flex;
    gap: 8px;
    margin-bottom: var(--space-10);
    justify-content: center;
  }

  .quiz__pill {
    height: 4px;
    flex: 1;
    max-width: 80px;
    border-radius: 99px;
    background: rgb(255 255 255 / 0.12);
    transition: background 0.25s;
  }

  .quiz__pill--active { background: #6C5CE7; }
  .quiz__pill--done   { background: #13C28A; }

  .quiz__q {}

  .quiz__qlabel {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.4);
    margin-bottom: var(--space-3);
  }

  .quiz__qtitle {
    font-size: clamp(var(--text-xl), 3vw, 28px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-8);
    line-height: 1.2;
  }

  .quiz__opts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .quiz__opts--3 { grid-template-columns: repeat(3, 1fr); }

  .quiz__opt {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    padding: 20px 22px;
    border-radius: 14px;
    border: 1px solid rgb(255 255 255 / 0.1);
    background: rgb(255 255 255 / 0.04);
    cursor: pointer;
    text-align: left;
    transition: border-color 0.15s, background 0.15s, transform 0.1s;
    color: white;
  }

  .quiz__opt:hover {
    border-color: #6C5CE7;
    background: rgb(108 92 231 / 0.12);
    transform: translateY(-1px);
  }

  .quiz__opt--selected {
    border-color: #6C5CE7;
    background: rgb(108 92 231 / 0.18);
  }

  .quiz__opt-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .quiz__opt-desc {
    font-size: 13px;
    color: rgb(255 255 255 / 0.5);
    line-height: 1.4;
  }

  /* Result */
  .quiz__result-inner {
    background: rgb(255 255 255 / 0.04);
