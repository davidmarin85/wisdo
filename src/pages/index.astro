</style>

<script>
  // ===== FILTER PILLS (marketplace) =====
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.tool-card');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter ?? 'all';
      pills.forEach(p => p.classList.remove('filter-pill--active'));
      pill.classList.add('filter-pill--active');
      cards.forEach(card => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
      });
    });
  });

  // ===== QUIZ =====
  const ARCHETYPES: Record<string, string> = {
    agency:     'The Operator',
    saas:       'The Builder',
    consultant: 'The Specialist',
    ecommerce:  'The Seller',
  };

  type StackDef = { name: string; tools: Record<string, string[]> };
  const STACKS: Record<string, StackDef> = {
    'generate-leads':    { name: 'Lead Generation Engine', tools: { low: ['apollo', 'kaspr'], medium: ['apollo', 'kaspr', 'lusha'], high: ['apollo', 'kaspr', 'lusha', 'lemlist'] } },
    'close-sales':       { name: 'Closing Machine',        tools: { low: ['lemlist', 'manychat'], medium: ['lemlist', 'apollo', 'manychat'], high: ['lemlist', 'apollo', 'manychat', 'krispcall'] } },
    'retain-customers':  { name: 'Retention Loop',         tools: { low: ['manychat'], medium: ['manychat', 'apollo'], high: ['manychat', 'apollo', 'lemlist'] } },
    'automate-ops':      { name: 'Automation Stack',       tools: { low: ['manychat', 'krispcall'], medium: ['manychat', 'krispcall', 'apollo'], high: ['manychat', 'krispcall', 'apollo', 'lemlist'] } },
  };

  const COST: Record<string, string> = { low: '~€90/mes', medium: '~€320/mes', high: '€500+/mes' };

  type ToolInfo = { name: string; mono: string; color: string; role: string; pricing: string; isFree: boolean };
  const QUIZ_TOOLS: Record<string, ToolInfo> = {
    apollo:    { name: 'Apollo.io',  mono: 'A',  color: '#3B4BF0', role: 'Base de datos & secuencias', pricing: 'Freemium', isFree: true },
    kaspr:     { name: 'Kaspr',      mono: 'K',  color: '#6C5CE7', role: 'LinkedIn enrichment',        pricing: 'Freemium', isFree: true },
    krispcall: { name: 'KrispCall',  mono: 'KC', color: '#13C28A', role: 'Llamadas cloud + IA',        pricing: 'Desde $15/mo', isFree: false },
    lemlist:   { name: 'Lemlist',    mono: 'L',  color: '#1E73FF', role: 'Cold outreach multichannel', pricing: 'Desde $39/mo', isFree: false },
    lusha:     { name: 'Lusha',      mono: 'Lu', color: '#FF6B2C', role: 'Enriquecimiento B2B',        pricing: 'Freemium', isFree: true },
    manychat:  { name: 'ManyChat',   mono: 'M',  color: '#00B36B', role: 'Chatbots & automatización',  pricing: 'Freemium', isFree: true },
  };

  const STEP_KEYS = ['biz', 'stage', 'problem', 'budget'] as const;
  type StepKey = typeof STEP_KEYS[number];
  const answers: Record<StepKey, string | null> = { biz: null, stage: null, problem: null, budget: null };
  let step = 1;

  const quizStepbar = document.getElementById('quiz-stepbar');
  const quizBack    = document.getElementById('quiz-back') as HTMLButtonElement | null;
  const quizRestart = document.getElementById('quiz-restart') as HTMLButtonElement | null;
  const quizNav     = document.getElementById('quiz-nav');
  const quizResult  = document.getElementById('quiz-result');

  function getQuizQ(n: number): HTMLElement | null {
    return document.getElementById(`quiz-q${n}`);
  }

  function updateStepbar() {
    quizStepbar?.querySelectorAll<HTMLElement>('[data-s]').forEach(el => {
      const s = parseInt(el.dataset.s ?? '0');
      el.classList.remove('quiz__pill--active', 'quiz__pill--done');
      if (s < step) el.classList.add('quiz__pill--done');
      else if (s === step) el.classList.add('quiz__pill--active');
    });
  }

  function showStep(n: number) {
    [1, 2, 3, 4].forEach(i => {
      const el = getQuizQ(i);
      if (el) el.hidden = (i !== n);
    });
    if (quizResult) quizResult.hidden = true;

    if (quizBack)    quizBack.hidden    = (n <= 1);
    if (quizRestart) quizRestart.hidden = true;
    if (quizNav)     quizNav.style.display = '';
    updateStepbar();
  }

  function showResult() {
    [1, 2, 3, 4].forEach(i => {
      const el = getQuizQ(i);
      if (el) el.hidden = true;
    });

    const archetype  = ARCHETYPES[answers.biz ?? 'saas'] ?? 'The Builder';
    const stackDef   = STACKS[answers.problem ?? 'generate-leads']!;
    const toolSlugs  = stackDef.tools[answers.budget ?? 'medium'] ?? [];
    const costLabel  = COST[answers.budget ?? 'medium'] ?? '';

    let toolsHtml = '';
    toolSlugs.forEach((slug, i) => {
      const t = QUIZ_TOOLS[slug];
      if (!t) return;
      toolsHtml += `
        <div class="quiz__tool-item">
          <span class="quiz__tool-num">${String(i + 1).padStart(2, '0')}</span>
          <span class="quiz__tool-mono" style="background:${t.color}">${t.mono}</span>
          <div class="quiz__tool-info">
            <div class="quiz__tool-name">${t.name}</div>
            <div class="quiz__tool-role">${t.role}</div>
          </div>
          ${t.isFree ? '<span class="quiz__tool-badge">FREE</span>' : ''}
        </div>
      `;
    });

    if (quizResult) {
      quizResult.innerHTML = `
        <div class="quiz__result-inner">
          <p class="quiz__archetype-label">Tu arquetipo</p>
          <h3 class="quiz__archetype">${archetype}</h3>
          <p class="quiz__stack-name">${stackDef.name}</p>
          <div class="quiz__tools-list">${toolsHtml}</div>
          <div class="quiz__result-footer">
            <div>
              <div class="quiz__cost-label">Inversión estimada</div>
              <div class="quiz__cost">${costLabel}</div>
            </div>
            <a href="/tools/" class="quiz__explore-btn">Explorar herramientas →</a>
          </div>
        </div>
      `;
      quizResult.hidden = false;
    }

    quizStepbar?.querySelectorAll<HTMLElement>('[data-s]').forEach(el => el.classList.add('quiz__pill--done'));
    if (quizBack)    quizBack.hidden    = true;
    if (quizRestart) quizRestart.hidden = false;
    if (quizNav)     quizNav.style.display = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.quiz__opt').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.key as StepKey;
      const val = btn.dataset.val ?? '';
      answers[key] = val;

      btn.parentElement?.querySelectorAll('.quiz__opt').forEach(b => b.classList.remove('quiz__opt--selected'));
      btn.classList.add('quiz__opt--selected');

      setTimeout(() => {
        if (step < 4) {
          step++;
          showStep(step);
        } else {
          showResult();
        }
      }, 200);
    });
  });

  quizBack?.addEventListener('click', () => {
    if (step > 1) {
      const prevKey = STEP_KEYS[step - 2] as StepKey;
      answers[STEP_KEYS[step - 1] as StepKey] = null;
      step--;
      showStep(step);
      const prevQ = getQuizQ(step);
      prevQ?.querySelectorAll('.quiz__opt').forEach(b => {
        if ((b as HTMLElement).dataset.val === answers[prevKey]) {
          b.classList.add('quiz__opt--selected');
        } else {
          b.classList.remove('quiz__opt--selected');
        }
      });
    }
  });

  quizRestart?.addEventListener('click', () => {
    (Object.keys(answers) as StepKey[]).forEach(k => { answers[k] = null; });
    step = 1;
    document.querySelectorAll('.quiz__opt').forEach(b => b.classList.remove('quiz__opt--selected'));
    showStep(1);
  });

  updateStepbar();

  // ===== COMPARATOR =====
  type CompToolInfo = { name: string; mono: string; color: string; category: string; bestFor: string; pricing: string; rating: string; link: string; cta: string };
  const COMP_TOOLS: Record<string, CompToolInfo> = {
    apollo:    { name: 'Apollo.io',  mono: 'A',  color: '#3B4BF0', category: 'Prospecting', bestFor: 'Outreach a escala',     pricing: 'Freemium · desde $49/mo',  rating: '4.7', link: 'https://www.apollo.io',      cta: 'Get Apollo' },
    kaspr:     { name: 'Kaspr',      mono: 'K',  color: '#6C5CE7', category: 'Prospecting', bestFor: 'LinkedIn lead gen',     pricing: 'Freemium · desde €30/mo',  rating: '4.4', link: 'https://www.kaspr.io',       cta: 'Get Kaspr' },
    krispcall: { name: 'KrispCall',  mono: 'KC', color: '#13C28A', category: 'Calling',     bestFor: 'Ventas telefónicas',    pricing: 'Desde $15/usuario/mo',     rating: '4.3', link: 'https://www.krispcall.com',  cta: 'Get KrispCall' },
    lemlist:   { name: 'Lemlist',    mono: 'L',  color: '#1E73FF', category: 'Outreach',    bestFor: 'Cold email multichannel', pricing: 'Desde $39/mo',           rating: '4.6', link: 'https://www.lemlist.com',    cta: 'Get Lemlist' },
    lusha:     { name: 'Lusha',      mono: 'Lu', color: '#FF6B2C', category: 'Prospecting', bestFor: 'Enriquecimiento B2B',   pricing: 'Freemium · desde $36/mo',  rating: '4.2', link: 'https://www.lusha.com',      cta: 'Get Lusha' },
    manychat:  { name: 'ManyChat',   mono: 'M',  color: '#00B36B', category: 'Automation',  bestFor: 'Chatbots & DMs',       pricing: 'Freemium · desde $15/mo',  rating: '4.5', link: 'https://manychat.com',       cta: 'Get ManyChat' },
  };

  const compChips   = document.querySelectorAll<HTMLButtonElement>('.comp-chip');
  const compOutput  = document.getElementById('comp-output');
  let selectedSlugs: string[] = [];

  function renderComparator() {
    if (!compOutput) return;
    if (selectedSlugs.length === 0) {
      compOutput.innerHTML = '<p class="comp-empty">Selecciona al menos una herramienta para comparar.</p>';
      return;
    }

    const cols = selectedSlugs.map(s => COMP_TOOLS[s]).filter((t): t is CompToolInfo => t !== undefined);
    const ROWS: { label: string; key: keyof CompToolInfo }[] = [
      { label: 'Categoría',  key: 'category' },
      { label: 'Ideal para', key: 'bestFor' },
      { label: 'Precio',     key: 'pricing' },
      { label: 'Valoración', key: 'rating' },
    ];

    let html = '<div class="comp-table-scroll"><table class="comp-table"><thead><tr>';
    html += '<th></th>';
    cols.forEach(t => {
      html += `<th><div class="comp-th-tool"><span class="comp-th-mono" style="background:${t.color}">${t.mono}</span><span class="comp-th-name">${t.name}</span></div></th>`;
    });
    html += '</tr></thead><tbody>';

    ROWS.forEach(row => {
      html += `<tr><td>${row.label}</td>`;
      cols.forEach(t => {
        const val = String(t[row.key]);
        if (row.key === 'rating') {
          html += `<td><span class="comp-rating"><svg width="13" height="13" viewBox="0 0 24 24" fill="#F5B33B" aria-hidden="true"><path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7z"/></svg>${val}</span></td>`;
        } else {
          html += `<td>${val}</td>`;
        }
      });
      html += '</tr>';
    });

    html += '</tbody><tfoot><tr><td></td>';
    cols.forEach(t => {
      html += `<td><a href="${t.link}" target="_blank" rel="noopener noreferrer" class="comp-cta">${t.cta} →</a></td>`;
    });
    html += '</tr></tfoot></table></div>';

    compOutput.innerHTML = html;
  }

  compChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const slug = chip.dataset.slug ?? '';
      const isSelected = chip.getAttribute('aria-pressed') === 'true';

      if (isSelected) {
        chip.setAttribute('aria-pressed', 'false');
        selectedSlugs = selectedSlugs.filter(s => s !== slug);
      } else {
        if (selectedSlugs.length >= 3) return;
        chip.setAttribute('aria-pressed', 'true');
        selectedSlugs.push(slug);
      }
      renderComparator();
    });
  });
</script>
