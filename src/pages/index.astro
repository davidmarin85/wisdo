---
import BaseLayout from '@layouts/BaseLayout.astro';
import ToolCard from '@components/ToolCard.astro';
import { tools, categories } from '@data/tools';

const featuredTools = tools.filter(t => t.featured);
---

<BaseLayout
  title="wisdo — El marketplace de herramientas para ventas"
  description="Encuentra, compara y elige las mejores herramientas de prospecting, outreach y automatización para tu equipo comercial."
  navVariant="dark"
>
  <!-- HERO — dark section -->
  <section class="hero">
    <div class="container hero__content">
      <p class="hero__eyebrow">The marketing &amp; sales tool marketplace</p>

      <h1 class="hero__title">
        Every tool to find,<br />
        <span class="hero__title-accent">reach &amp; close</span> more customers.
      </h1>

      <p class="hero__subtitle">
        Herramientas evaluadas y comparadas para equipos comerciales<br class="hide-mobile" />
        en Latinoamérica. Sin afiliados, sin sesgos.
      </p>

      <form class="hero__search" action="/tools/" method="get" role="search">
        <svg class="hero__search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="search"
          name="q"
          placeholder="Busca herramientas, casos de uso…"
          class="hero__search-input"
          aria-label="Buscar herramientas"
          autocomplete="off"
        />
        <button type="submit" class="hero__search-btn">Buscar</button>
      </form>

      <div class="hero__popular">
        <span class="hero__popular-label">Popular:</span>
        <a href="/tools/?q=cold+email" class="hero__popular-tag">Cold email</a>
        <a href="/tools/?q=linkedin" class="hero__popular-tag">LinkedIn data</a>
        <a href="/tools/?q=chatbot" class="hero__popular-tag">Chatbots</a>
        <a href="/tools/?q=lead+gen" class="hero__popular-tag">Lead gen</a>
      </div>

      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-value">25+</span>
          <span class="hero__stat-label">Herramientas evaluadas</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-value">5</span>
          <span class="hero__stat-label">Categorías</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-value">100%</span>
          <span class="hero__stat-label">Hand-picked</span>
        </div>
      </div>
    </div>
  </section>

  <!-- MARKETPLACE — light section -->
  <section class="marketplace" id="marketplace">
    <div class="container">
      <div class="marketplace__header">
        <div>
          <h2 class="marketplace__title">Herramientas destacadas</h2>
          <p class="marketplace__subtitle">Las favoritas de los equipos de ventas en Latinoamérica</p>
        </div>
        <a href="/tools/" class="btn btn--outline-dark">
          Ver todas →
        </a>
      </div>

      <!-- Category filter pills -->
      <div class="filter-pills" role="group" aria-label="Filtrar por categoría">
        {categories.map(cat => (
          <button
            class:list={['filter-pill', { 'filter-pill--active': cat.slug === 'all' }]}
            data-filter={cat.slug}
            type="button"
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Tool grid -->
      <div class="tool-grid" id="tool-grid">
        {featuredTools.map(tool => (
          <ToolCard tool={tool} />
        ))}
      </div>

      <div class="marketplace__cta">
        <p>¿No encuentras lo que buscas?</p>
        <a href="/tools/" class="btn btn--purple">
          Ver el directorio completo
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- HERO ---- */
  .hero {
    background:
      radial-gradient(900px 460px at 72% -8%, rgba(108, 92, 231, 0.42), transparent 58%),
      radial-gradient(700px 400px at 8% 20%, rgba(19, 194, 138, 0.12), transparent 60%),
      #14121F;
    color: white;
    padding: var(--space-32) 0 var(--space-24);
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
  }

  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #9D8CFF;
    margin-bottom: var(--space-1);
  }

  .hero__title {
    font-size: clamp(var(--text-4xl), 6vw, 60px);
    font-weight: var(--font-bold);
    letter-spacing: -0.03em;
    line-height: var(--leading-tight);
    color: white;
    max-width: 16ch;
  }

  .hero__title-accent {
    background: linear-gradient(135deg, #A89AFF 0%, var(--color-green) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: var(--text-base);
    color: rgb(255 255 255 / 0.6);
    line-height: var(--leading-relaxed);
    max-width: 50ch;
  }

  /* Search bar */
  .hero__search {
    display: flex;
    align-items: center;
    max-width: 520px;
    width: 100%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 14px;
    padding: 6px 8px 6px 18px;
    gap: 10px;
    margin-top: var(--space-2);
  }

  .hero__search-icon {
    color: rgb(255 255 255 / 0.4);
    flex-shrink: 0;
  }

  .hero__search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: 15px;
    color: white;
    color-scheme: dark;
    min-width: 0;
  }

  .hero__search-input::placeholder {
    color: rgb(255 255 255 / 0.35);
  }

  .hero__search-btn {
    padding: 10px 20px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    background: var(--color-green);
    color: #0B1F17;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .hero__search-btn:hover {
    opacity: 0.88;
  }

  /* Popular tags */
  .hero__popular {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__popular-label {
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgb(255 255 255 / 0.4);
  }

  .hero__popular-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgb(255 255 255 / 0.65);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 4px 12px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .hero__popular-tag:hover {
    background: rgba(255, 255, 255, 0.12);
    color: white;
  }

  /* Stats */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-10);
    margin-top: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid rgb(255 255 255 / 0.08);
    width: 100%;
    justify-content: center;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .hero__stat-value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: white;
    letter-spacing: -0.02em;
  }

  .hero__stat-label {
    font-size: var(--text-xs);
    color: rgb(255 255 255 / 0.45);
    font-family: var(--font-mono);
    letter-spacing: 0.3px;
  }

  .hero__stat-divider {
    width: 1px;
    height: 40px;
    background-color: rgb(255 255 255 / 0.1);
  }

  /* ---- MARKETPLACE ---- */
  .marketplace {
    background-color: var(--color-white);
    padding: var(--space-20) 0 var(--space-24);
  }

  .marketplace__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .marketplace__title {
    font-size: var(--text-3xl);
    color: var(--color-dark);
    margin-bottom: var(--space-2);
  }

  .marketplace__subtitle {
    color: var(--color-text-muted);
    font-size: var(--text-base);
  }

  /* ---- FILTER PILLS ---- */
  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .filter-pill {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-gray-200);
    background-color: var(--color-white);
    color: var(--color-gray-600);
    cursor: pointer;
    transition: background-color var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
  }

  .filter-pill:hover {
    border-color: var(--color-purple);
    color: var(--color-purple);
  }

  .filter-pill--active {
    background-color: var(--color-purple);
    border-color: var(--color-purple);
    color: white;
  }

  /* ---- TOOL GRID ---- */
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
    margin-bottom: var(--space-12);
  }

  /* ---- MARKETPLACE CTA ---- */
  .marketplace__cta {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    justify-content: center;
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-border);
  }

  .marketplace__cta p {
    color: var(--color-text-muted);
    font-size: var(--text-base);
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 640px) {
    .hero {
      min-height: auto;
      padding: var(--space-20) 0 var(--space-16);
    }

    .hero__stats {
      gap: var(--space-5);
    }

    .hero__stat-value {
      font-size: var(--text-2xl);
    }

    .hide-mobile {
      display: none;
    }

    .marketplace__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .marketplace__cta {
      flex-direction: column;
      text-align: center;
    }

    .tool-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.tool-card');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter ?? 'all';

      pills.forEach(p => p.classList.remove('filter-pill--active'));
      pill.classList.add('filter-pill--active');

      cards.forEach(card => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>
