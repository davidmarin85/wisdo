---
import BaseLayout from '@layouts/BaseLayout.astro';
import { createSupabaseServerClient } from '@lib/supabase';
import { getOAuthRedirectUrl } from '@lib/auth';

const supabase = createSupabaseServerClient({ request: Astro.request, cookies: Astro.cookies });
const { data: { user } } = await supabase.auth.getUser();

if (user) return Astro.redirect('/dashboard/', 302);

const next = Astro.url.searchParams.get('next') ?? '/dashboard/';
const error = Astro.url.searchParams.get('error');

const { data: oauthData, error: oauthError } = await supabase.auth.signInWithOAuth({
  provider: 'google',
  options: {
    redirectTo: `${getOAuthRedirectUrl()}?next=${encodeURIComponent(next)}`,
    queryParams: { access_type: 'offline', prompt: 'consent' },
    skipBrowserRedirect: true,
  },
});

if (oauthError || !oauthData.url) {
  throw new Error('Failed to build OAuth URL');
}

const googleUrl = oauthData.url;
---

<BaseLayout title="Sign in — wisdo" description="Sign in to wisdo." noindex={true}>
  <div class="login-container">
    <h1>Sign in</h1>

    {error && <p class="error-message" role="alert">Authentication failed. Please try again.</p>}

    <a href={googleUrl} class="btn-google">
      <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
        <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
        <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
        <path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/>
        <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z"/>
      </svg>
      Continue with Google
    </a>
  </div>
</BaseLayout>

<style>
  .login-container {
    max-width: 24rem;
    margin: var(--space-16) auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    align-items: center;
    text-align: center;
  }

  .btn-google {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-6);
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    font-weight: var(--font-medium);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-fast);
  }

  .btn-google:hover {
    box-shadow: var(--shadow-md);
    color: var(--color-text);
  }

  .error-message {
    color: var(--color-error);
    font-size: var(--text-sm);
  }
</style>
